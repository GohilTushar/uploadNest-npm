{
  "name": "@tusharg_33/uploadnest-sdk",
  "version": "1.0.1",
  "description": "Officical typesscript librabry for the upload Nest API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./errors": {
      "import": "./dist/errors.mjs",
      "require": "./dist/errors.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "changeset": "npx changeset",
    "version-packages": "npx changeset version",
    "release": "npm run build && npm run version-packages && npx changeset publish",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "url":"https://github.com/GohilTushar/uploadNest-npm"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "uploadNest",
    "file-upload",
    "storage",
    "typescript",
    "nodejs",
    "nextjs"
  ],
  "author": "TusharG",
  "license": "Apache-2.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/node": "^26.0.0",
    "form-data": "^4.0.6",
    "rimraf": "^6.1.3"
  }
}
